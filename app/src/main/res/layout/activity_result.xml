<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvVictory"
        style="@style/TextStyle.Title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MISSION COMPLETE"
        android:textSize="32sp"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Rank Display -->
    <LinearLayout
        android:id="@+id/rankContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/tvVictory">

        <!-- 1st Place -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardRank1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/color_surface"
            app:strokeColor="@color/color_primary"
            app:strokeWidth="2dp"
            app:cardCornerRadius="16dp"
            android:layout_marginBottom="12dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvRank1"
                    style="@style/TextStyle.Title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1ST"
                    android:textSize="24sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <TextView
                    android:id="@+id/tvName1"
                    style="@style/TextStyle.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PLAYER 1"
                    android:textSize="20sp"
                    android:layout_marginStart="24dp"
                    app:layout_constraintStart_toEndOf="@id/tvRank1"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <TextView
                    android:id="@+id/tvScore1"
                    style="@style/TextStyle.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2500"
                    android:textColor="@color/color_primary"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 2nd Place -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/color_surface"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="12dp"
            android:alpha="0.8">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp">
                <TextView style="@style/TextStyle.Body" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2ND" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                <TextView style="@style/TextStyle.Body" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PLAYER 2" android:layout_marginStart="24dp" app:layout_constraintStart_toStartOf="parent" app:layout_constraintHorizontal_bias="0.3" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                <TextView style="@style/TextStyle.Body" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1800" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- Stats -->
    <TextView
        android:id="@+id/tvTimeTaken"
        style="@style/TextStyle.Body"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TIME: 01:45"
        android:alpha="0.6"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/rankContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="24dp">

        <Button
            android:id="@+id/btnPlayAgain"
            style="@style/ButtonStyle.Neon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PLAY AGAIN"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnMainMenu"
            style="@style/ButtonStyle.Neon.Orange"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MAIN MENU" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>