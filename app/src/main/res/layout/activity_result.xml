<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:padding="24dp">

    <TextView android:id="@+id/tvResult"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="RESULT" android:textSize="@dimen/text_size_body"
        android:textColor="@color/color_text_hint" android:fontFamily="@font/rajdhani"
        android:letterSpacing="0.3"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp" />

    <TextView android:id="@+id/tvWinner"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="🏆 PLAYER"
        android:textSize="34sp" android:textColor="@color/color_secondary"
        android:fontFamily="@font/orbitron" android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tvResult"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp" />

    <TextView android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="wins the race!" android:textSize="@dimen/text_size_body"
        android:textColor="@color/color_primary" android:fontFamily="@font/rajdhani"
        app:layout_constraintTop_toBottomOf="@id/tvWinner"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <TextView android:id="@+id/tvTimeLbl"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="YOUR TIME"
        android:textSize="@dimen/text_size_caption" android:textColor="@color/color_text_hint"
        android:fontFamily="@font/rajdhani" android:letterSpacing="0.2"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp" />

    <TextView android:id="@+id/tvTime"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="00:00.0"
        android:textSize="48sp" android:textColor="@color/color_primary"
        android:fontFamily="@font/orbitron" android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tvTimeLbl"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp" />

    <!-- Online ranking section -->
    <LinearLayout android:id="@+id/groupOnline"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/color_surface"
        android:padding="16dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvTime"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="LEADERBOARD" android:textSize="@dimen/text_size_caption"
            android:textColor="@color/color_text_hint" android:fontFamily="@font/rajdhani"
            android:letterSpacing="0.2" android:layout_marginBottom="8dp" />

        <TextView android:id="@+id/tvRanking"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="" android:textSize="@dimen/text_size_body"
            android:textColor="@color/color_text_primary" android:fontFamily="@font/rajdhani"
            android:lineSpacingMultiplier="1.6" />
    </LinearLayout>

    <!-- Buttons -->
    <LinearLayout android:id="@+id/btnsGroup"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp">

        <Button android:id="@+id/btnPlayAgain"
            style="@style/ButtonStyle.Neon"
            android:layout_width="match_parent" android:layout_height="@dimen/button_height"
            android:text="▶ PLAY AGAIN"
            android:layout_marginBottom="10dp" />

        <Button android:id="@+id/btnHome"
            style="@style/ButtonStyle.Neon.Orange"
            android:layout_width="match_parent" android:layout_height="@dimen/button_height"
            android:text="⌂ HOME" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>