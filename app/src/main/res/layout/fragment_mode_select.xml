<?xml version="1.0" encoding="utf-8"?>
<!--
    STEP 1 – MODE SELECTION
    3 tappable cards: VS PLAYER | VS AI | SOLO
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/color_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_screen">

        <!-- Section title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/mode_select_title"
            android:textSize="22sp"
            android:textColor="@color/color_primary"
            android:textStyle="bold"
            android:fontFamily="@font/orbitron"
            android:letterSpacing="0.1"
            android:layout_marginBottom="20dp" />

        <!-- ── VS PLAYER card ── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardVsPlayer"
            android:layout_width="match_parent"
            android:layout_height="@dimen/mode_card_min_height"
            android:layout_marginBottom="14dp"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/color_surface"
            app:cardCornerRadius="@dimen/radius_lg"
            app:cardElevation="6dp"
            app:strokeColor="@color/color_primary"
            app:strokeWidth="1.5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/padding_card">

                <!-- Icon -->
                <ImageView
                    android:layout_width="@dimen/icon_xl"
                    android:layout_height="@dimen/icon_xl"
                    android:src="@drawable/ic_players"
                    android:contentDescription="@null" />

                <!-- Text content -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mode_vs_player"
                        android:textSize="@dimen/text_size_body_lg"
                        android:textColor="@color/color_primary"
                        android:textStyle="bold"
                        android:fontFamily="@font/orbitron"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mode_vs_player_sub"
                        android:textSize="@dimen/text_size_caption"
                        android:textColor="@color/color_text_secondary"
                        android:fontFamily="@font/rajdhani"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <!-- Selected indicator -->
                <View
                    android:id="@+id/indicatorVsPlayer"
                    android:layout_width="4dp"
                    android:layout_height="36dp"
                    android:background="@color/color_primary"
                    android:visibility="invisible" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── VS AI card ── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardVsAi"
            android:layout_width="match_parent"
            android:layout_height="@dimen/mode_card_min_height"
            android:layout_marginBottom="14dp"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/color_surface"
            app:cardCornerRadius="@dimen/radius_lg"
            app:cardElevation="6dp"
            app:strokeColor="@color/color_divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/padding_card">

                <ImageView
                    android:layout_width="@dimen/icon_xl"
                    android:layout_height="@dimen/icon_xl"
                    android:src="@drawable/ic_robot"
                    android:contentDescription="@null" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mode_vs_ai"
                        android:textSize="@dimen/text_size_body_lg"
                        android:textColor="@color/color_secondary"
                        android:textStyle="bold"
                        android:fontFamily="@font/orbitron"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mode_vs_ai_sub"
                        android:textSize="@dimen/text_size_caption"
                        android:textColor="@color/color_text_secondary"
                        android:fontFamily="@font/rajdhani"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <View
                    android:id="@+id/indicatorVsAi"
                    android:layout_width="4dp"
                    android:layout_height="36dp"
                    android:background="@color/color_secondary"
                    android:visibility="invisible" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── SOLO card ── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardSolo"
            android:layout_width="match_parent"
            android:layout_height="@dimen/mode_card_min_height"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/color_surface"
            app:cardCornerRadius="@dimen/radius_lg"
            app:cardElevation="6dp"
            app:strokeColor="@color/color_divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/padding_card">

                <ImageView
                    android:layout_width="@dimen/icon_xl"
                    android:layout_height="@dimen/icon_xl"
                    android:src="@drawable/ic_solo"
                    android:contentDescription="@null" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mode_solo"
                        android:textSize="@dimen/text_size_body_lg"
                        android:textColor="@color/color_tertiary"
                        android:textStyle="bold"
                        android:fontFamily="@font/orbitron"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mode_solo_sub"
                        android:textSize="@dimen/text_size_caption"
                        android:textColor="@color/color_text_secondary"
                        android:fontFamily="@font/rajdhani"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <View
                    android:id="@+id/indicatorSolo"
                    android:layout_width="4dp"
                    android:layout_height="36dp"
                    android:background="@color/color_tertiary"
                    android:visibility="invisible" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
