<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <com.example.ampg08.view.ParticleView
        android:id="@+id/particleView"
        android:layout_width="0dp" android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- User info card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardUser"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/color_surface"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        android:layout_margin="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:padding="16dp" android:orientation="horizontal" android:gravity="center_vertical">

            <TextView android:layout_width="52dp" android:layout_height="52dp"
                android:text="👤" android:textSize="32sp" android:gravity="center" />

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                <TextView android:id="@+id/tvUsername"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Player" android:textColor="@color/color_text_primary"
                    android:textSize="18sp" android:fontFamily="@font/rajdhani" android:textStyle="bold" />
                <TextView android:id="@+id/tvStats"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0 thắng / 0 trận" android:textColor="@color/color_primary"
                    android:textSize="13sp" android:fontFamily="@font/rajdhani" />
            </LinearLayout>

            <ImageButton android:id="@+id/btnLogout"
                android:layout_width="36dp" android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/color_secondary" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitleHome"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="TILT ARENA"
        android:textSize="36sp" android:textColor="@color/color_primary"
        android:fontFamily="@font/orbitron" android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/cardUser"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- Buttons -->
    <LinearLayout
        android:id="@+id/menuButtons"
        android:layout_width="300dp" android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/tvTitleHome"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button android:id="@+id/btnCreate"
            style="@style/ButtonStyle.Neon.Large"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:text="⊕  CREATE ROOM"
            android:layout_marginBottom="12dp" />

        <Button android:id="@+id/btnJoin"
            style="@style/ButtonStyle.Neon"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="↗  JOIN ROOM"
            android:layout_marginBottom="12dp" />

        <Button android:id="@+id/btnPractice"
            style="@style/ButtonStyle.Neon"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="⚡  PRACTICE"
            android:layout_marginBottom="12dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button android:id="@+id/btnLeaderboard"
                style="@style/ButtonStyle.Neon.Orange"
                android:layout_width="0dp" android:layout_height="48dp"
                android:layout_weight="1" android:text="🏆"
                android:layout_marginEnd="6dp" />
            <Button android:id="@+id/btnProfile"
                style="@style/ButtonStyle.Neon"
                android:layout_width="0dp" android:layout_height="48dp"
                android:layout_weight="1" android:text="👤"
                android:layout_marginStart="6dp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
