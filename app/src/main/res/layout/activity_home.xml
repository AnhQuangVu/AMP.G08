<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <com.example.ampg08.view.ParticleView
        android:id="@+id/particleView"
        android:layout_width="0dp" android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- User info card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardUser"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/color_surface"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        android:layout_margin="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:padding="16dp" android:orientation="horizontal" android:gravity="center_vertical">

            <ImageView
                android:layout_width="52dp"
                android:layout_height="@dimen/button_height"
                android:src="@drawable/ic_profile"
                android:contentDescription="@string/profile"
                app:tint="@color/color_primary"
                android:padding="8dp" />

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                <TextView android:id="@+id/tvUsername"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/home_player_default" android:textColor="@color/color_text_primary"
                    android:textSize="@dimen/text_size_body_lg" android:fontFamily="@font/rajdhani" android:textStyle="bold" />
                <TextView android:id="@+id/tvStats"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/home_stats_default" android:textColor="@color/color_primary"
                    android:textSize="@dimen/text_size_caption" android:fontFamily="@font/rajdhani" />
            </LinearLayout>

            <ImageButton android:id="@+id/btnLogout"
                android:layout_width="48dp" android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="12dp"
                app:tint="@color/color_secondary"
                android:contentDescription="@string/logout" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitleHome"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/home_title"
        android:textSize="36sp" android:textColor="@color/color_primary"
        android:fontFamily="@font/orbitron" android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/cardUser"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- Buttons -->
    <LinearLayout
        android:id="@+id/menuButtons"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitleHome"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button android:id="@+id/btnQuickMatch"
            style="@style/ButtonStyle.Neon.Large"
            android:layout_width="match_parent" android:layout_height="@dimen/button_height"
            android:text="⚡ QUICK MATCH"
            android:layout_marginBottom="12dp" />

        <Button android:id="@+id/btnCreate"
            style="@style/ButtonStyle.Neon"
            android:layout_width="match_parent" android:layout_height="@dimen/button_height"
            android:text="@string/home_btn_create_room"
            android:layout_marginBottom="12dp" />

        <Button android:id="@+id/btnJoin"
            style="@style/ButtonStyle.Neon"
            android:layout_width="match_parent" android:layout_height="@dimen/button_height"
            android:text="@string/home_btn_join_room"
            android:layout_marginBottom="12dp" />

        <Button android:id="@+id/btnPractice"
            style="@style/ButtonStyle.Neon"
            android:layout_width="match_parent" android:layout_height="@dimen/button_height"
            android:text="@string/home_btn_practice"
            android:layout_marginBottom="12dp" />

        <Button android:id="@+id/btnMatchSetup"
            style="@style/ButtonStyle.Neon"
            android:layout_width="match_parent" android:layout_height="@dimen/button_height"
            android:text="@string/home_btn_match_setup"
            android:layout_marginBottom="12dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            <Button android:id="@+id/btnScore"
                style="@style/ButtonStyle.Neon"
                android:layout_width="0dp" android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@null"
                android:drawableTop="@drawable/ic_score"
                android:drawableTint="@color/color_primary"
                android:gravity="center"
                android:contentDescription="@string/home_btn_score"
                android:layout_marginEnd="6dp" />
            <Button android:id="@+id/btnSettings"
                style="@style/ButtonStyle.Neon"
                android:layout_width="0dp" android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@null"
                android:drawableTop="@drawable/ic_settings"
                android:drawableTint="@color/color_primary"
                android:gravity="center"
                android:contentDescription="@string/home_btn_settings"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button android:id="@+id/btnLeaderboard"
                style="@style/ButtonStyle.Neon"
                android:layout_width="0dp" android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@null"
                android:drawableTop="@drawable/ic_leaderboard"
                android:drawableTint="@color/color_primary"
                android:gravity="center"
                android:contentDescription="@string/home_btn_leaderboard"
                android:layout_marginEnd="6dp" />
            <Button android:id="@+id/btnProfile"
                style="@style/ButtonStyle.Neon"
                android:layout_width="0dp" android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@null"
                android:drawableTop="@drawable/ic_profile"
                android:drawableTint="@color/color_primary"
                android:gravity="center"
                android:contentDescription="@string/home_btn_profile"
                android:layout_marginStart="6dp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
