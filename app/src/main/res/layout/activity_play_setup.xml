<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <!-- Header -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_back"
        android:layout_margin="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:tint="@color/color_primary" />

    <TextView
        android:id="@+id/tvSetupTitle"
        style="@style/TextStyle.Title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/setup_title"
        android:textSize="20sp"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toEndOf="@id/btnBack"
        android:layout_marginStart="8dp" />

    <!-- Step Indicators -->
    <LinearLayout
        android:id="@+id/stepIndicator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="32dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/btnBack">

        <View
            android:id="@+id/step1"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:layout_weight="1"
            android:background="@color/color_primary"
            android:layout_marginEnd="4dp" />

        <View
            android:id="@+id/step2"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:layout_weight="1"
            android:background="@color/color_surface"
            android:layout_marginHorizontal="4dp" />

        <View
            android:id="@+id/step3"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:layout_weight="1"
            android:background="@color/color_surface"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <!-- Content Scroll -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:padding="24dp"
        app:layout_constraintTop_toBottomOf="@id/stepIndicator"
        app:layout_constraintBottom_toTopOf="@id/btnStart">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- STEP 1: MODES -->
            <TextView
                style="@style/TextStyle.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/step_mode"
                android:textSize="16sp"
                android:textColor="@color/color_secondary" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Mode Card: VS Player -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardVsPlayer"
                        android:layout_width="140dp"
                        android:layout_height="180dp"
                        app:cardBackgroundColor="@color/color_surface"
                        app:strokeColor="@color/color_primary"
                        app:strokeWidth="2dp"
                        app:cardCornerRadius="12dp"
                        android:layout_marginEnd="16dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@drawable/ic_players"
                                app:tint="@color/color_primary" />
                            <TextView
                                style="@style/TextStyle.Body"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/mode_vs_player"
                                android:layout_marginTop="12dp"
                                android:gravity="center" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Mode Card: VS AI -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardVsAI"
                        android:layout_width="140dp"
                        android:layout_height="180dp"
                        app:cardBackgroundColor="@color/color_surface"
                        app:strokeColor="@android:color/transparent"
                        app:cardCornerRadius="12dp"
                        android:layout_marginEnd="16dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@drawable/ic_robot"
                                app:tint="@color/color_text_hint" />
                            <TextView
                                style="@style/TextStyle.Body"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/mode_vs_ai"
                                android:layout_marginTop="12dp"
                                android:gravity="center" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- STEP 2: MAPS -->
            <TextView
                style="@style/TextStyle.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/step_map"
                android:textSize="16sp"
                android:textColor="@color/color_secondary"
                android:layout_marginTop="32dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMaps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@android:layout/simple_list_item_1" />

            <View
                android:layout_width="match_parent"
                android:layout_height="100dp" /> <!-- Bottom Spacer -->

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnStart"
        style="@style/ButtonStyle.Neon.Orange"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="@string/btn_start"
        android:layout_margin="24dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>