<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <!-- Header -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_back"
        android:layout_margin="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:tint="@color/color_primary" />

    <TextView
        android:id="@+id/tvSetupTitle"
        style="@style/TextStyle.Title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/setup_title"
        android:textSize="@dimen/text_size_subtitle"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toEndOf="@id/btnBack"
        android:layout_marginStart="8dp" />

    <!-- Step Indicators -->
    <LinearLayout
        android:id="@+id/stepIndicator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="32dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/btnBack">

        <View
            android:id="@+id/step1"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:layout_weight="1"
            android:background="@color/color_primary"
            android:layout_marginEnd="4dp" />

        <View
            android:id="@+id/step2"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:layout_weight="1"
            android:background="@color/color_surface"
            android:layout_marginHorizontal="4dp" />

        <View
            android:id="@+id/step3"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:layout_weight="1"
            android:background="@color/color_surface"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <!-- Content Scroll -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:padding="24dp"
        app:layout_constraintTop_toBottomOf="@id/stepIndicator"
        app:layout_constraintBottom_toTopOf="@id/btnStart">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- STEP 1: MODES -->
            <TextView
                style="@style/TextStyle.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/step_mode"
                android:textSize="@dimen/text_size_body"
                android:textColor="@color/color_secondary" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Mode Card: VS Player -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardVsPlayer"
                        android:layout_width="140dp"
                        android:layout_height="180dp"
                        app:cardBackgroundColor="@color/color_surface"
                        app:strokeColor="@color/color_primary"
                        app:strokeWidth="2dp"
                        app:cardCornerRadius="12dp"
                        android:layout_marginEnd="16dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@drawable/ic_players"
                                app:tint="@color/color_primary" />
                            <TextView
                                style="@style/TextStyle.Body"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/mode_vs_player"
                                android:layout_marginTop="12dp"
                                android:gravity="center" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Mode Card: VS AI -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardVsAI"
                        android:layout_width="140dp"
                        android:layout_height="180dp"
                        app:cardBackgroundColor="@color/color_surface"
                        app:strokeColor="@android:color/transparent"
                        app:cardCornerRadius="12dp"
                        android:layout_marginEnd="16dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@drawable/ic_robot"
                                app:tint="@color/color_text_hint" />
                            <TextView
                                style="@style/TextStyle.Body"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/mode_vs_ai"
                                android:layout_marginTop="12dp"
                                android:gravity="center" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- STEP 2: MAPS -->
            <TextView
                style="@style/TextStyle.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/step_map"
                android:textSize="@dimen/text_size_body"
                android:textColor="@color/color_secondary"
                android:layout_marginTop="32dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMaps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_map" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMapPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/color_surface"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/color_primary"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvSelectedMapName"
                        style="@style/TextStyle.Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_size_body_lg"
                        tools:text="Beginner Maze" />

                    <LinearLayout
                        android:id="@+id/starsContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/star1"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_star_filled" />

                        <ImageView
                            android:id="@+id/star2"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginStart="2dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_star_empty" />

                        <ImageView
                            android:id="@+id/star3"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginStart="2dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_star_empty" />

                        <ImageView
                            android:id="@+id/star4"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginStart="2dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_star_empty" />

                        <ImageView
                            android:id="@+id/star5"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginStart="2dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_star_empty" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvSelectedMapDiff"
                        style="@style/TextStyle.Body"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textStyle="bold"
                        tools:text="EASY" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- STEP 3: MATCH SETTINGS -->
            <TextView
                style="@style/TextStyle.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/match_setup_title"
                android:textSize="@dimen/text_size_body"
                android:textColor="@color/color_secondary"
                android:layout_marginTop="24dp" />

            <LinearLayout
                android:id="@+id/sectionPlayerCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_players"
                    android:textSize="@dimen/text_size_caption"
                    android:textColor="@color/color_text_secondary"
                    android:fontFamily="@font/rajdhani"
                    android:textAllCaps="true"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btn2Players"
                        style="@style/ButtonStyle.Neon.Large"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/button_height"
                        android:layout_weight="1"
                        android:text="2"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/btn3Players"
                        style="@style/ButtonStyle.Neon"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/button_height"
                        android:layout_weight="1"
                        android:text="3"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/btn4Players"
                        style="@style/ButtonStyle.Neon"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/button_height"
                        android:layout_weight="1"
                        android:text="4" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/sectionAiDifficulty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_ai_difficulty"
                    android:textSize="@dimen/text_size_caption"
                    android:textColor="@color/color_text_secondary"
                    android:fontFamily="@font/rajdhani"
                    android:textAllCaps="true"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnAiEasy"
                        style="@style/ButtonStyle.Neon.Large"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/button_height"
                        android:layout_weight="1"
                        android:text="@string/ai_easy"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/btnAiNormal"
                        style="@style/ButtonStyle.Neon"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/button_height"
                        android:layout_weight="1"
                        android:text="@string/ai_normal"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/btnAiHard"
                        style="@style/ButtonStyle.Neon"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/button_height"
                        android:layout_weight="1"
                        android:text="@string/ai_hard" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_time_limit"
                android:textSize="@dimen/text_size_caption"
                android:textColor="@color/color_text_secondary"
                android:fontFamily="@font/rajdhani"
                android:textAllCaps="true"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="10dp" />

            <RadioGroup
                android:id="@+id/rgTimeLimit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rb1Min"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/time_1min"
                    android:textColor="@color/color_text_primary"
                    android:buttonTint="@color/color_primary"
                    android:fontFamily="@font/rajdhani"
                    android:textSize="@dimen/text_size_caption" />

                <RadioButton
                    android:id="@+id/rb3Min"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/time_3min"
                    android:textColor="@color/color_text_primary"
                    android:buttonTint="@color/color_primary"
                    android:fontFamily="@font/rajdhani"
                    android:textSize="@dimen/text_size_caption"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/rb5Min"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/time_5min"
                    android:textColor="@color/color_text_primary"
                    android:buttonTint="@color/color_primary"
                    android:fontFamily="@font/rajdhani"
                    android:textSize="@dimen/text_size_caption" />

                <RadioButton
                    android:id="@+id/rbNoLimit"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/time_unlimited"
                    android:textColor="@color/color_text_primary"
                    android:buttonTint="@color/color_primary"
                    android:fontFamily="@font/rajdhani"
                    android:textSize="@dimen/text_size_caption" />
            </RadioGroup>

            <View
                android:layout_width="match_parent"
                android:layout_height="24dp" />

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnStart"
        style="@style/ButtonStyle.Neon.Orange"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height_lg"
        android:text="@string/btn_start"
        android:layout_margin="24dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>