<?xml version="1.0" encoding="utf-8"?>
<!--
    Downloadable font: Orbitron (Google Fonts)
    To activate: use Android Studio > More Fonts > search "Orbitron"
    and let it regenerate this file + font_certs.xml automatically.
    The app will gracefully fall back to sans-serif-condensed if unavailable.
-->
<font-family xmlns:app="http://schemas.android.com/apk/res-auto"
    app:fontProviderAuthority="com.google.android.gms.fonts"
    app:fontProviderPackage="com.google.android.gms"
    app:fontProviderQuery="Orbitron"
    app:fontProviderCerts="@array/com_google_android_gms_fonts_certs">
</font-family>
