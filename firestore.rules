rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function roomPath(roomId) {
      return /databases/$(database)/documents/rooms/$(roomId);
    }

    function roomExists(roomId) {
      return exists(roomPath(roomId));
    }

    function roomDoc(roomId) {
      return get(roomPath(roomId));
    }

    function isRoomHost(roomId) {
      return signedIn()
        && roomExists(roomId)
        && roomDoc(roomId).data.hostUid == request.auth.uid;
    }

    function isRoomMember(roomId) {
      return signedIn()
        && roomExists(roomId)
        && request.auth.uid in roomDoc(roomId).data.players;
    }

    function hostStatusUpdateOnly(roomId) {
      return isRoomHost(roomId)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status'])
        && request.resource.data.status in ['waiting', 'playing', 'ended']
        && request.resource.data.hostUid == resource.data.hostUid
        && request.resource.data.mapSeed == resource.data.mapSeed
        && request.resource.data.players == resource.data.players
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function playerJoinOrLeaveSelfOnly() {
      return resource.data.status == 'waiting'
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['players'])
        && (
          (
            request.auth.uid in request.resource.data.players
            && !(request.auth.uid in resource.data.players)
            && request.resource.data.players.size() == resource.data.players.size() + 1
            && request.resource.data.players.hasAll(resource.data.players)
          )
          ||
          (
            !(request.auth.uid in request.resource.data.players)
            && request.auth.uid in resource.data.players
            && request.resource.data.players.size() + 1 == resource.data.players.size()
            && resource.data.players.hasAll(request.resource.data.players)
          )
        );
    }

    function ownPlayerUpdateAllowed(uid) {
      return request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.displayName == resource.data.displayName
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'x', 'y', 'ready', 'finishTime', 'freezeRequested', 'updatedAt'
        ]);
    }

    function freezeOpponentAllowed(roomId, uid) {
      return request.auth.uid != uid
        && roomDoc(roomId).data.status == 'playing'
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.displayName == resource.data.displayName
        && request.resource.data.x == resource.data.x
        && request.resource.data.y == resource.data.y
        && request.resource.data.ready == resource.data.ready
        && request.resource.data.finishTime == resource.data.finishTime
        && request.resource.data.updatedAt == resource.data.updatedAt
        && resource.data.freezeRequested == false
        && request.resource.data.freezeRequested == true;
    }

    // Users
    match /users/{uid} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == uid;
      allow update: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == uid;
      allow delete: if false;

      match /friends/{friendUid} {
        allow read: if signedIn() && request.auth.uid == uid;
        allow create, update, delete: if signedIn() && request.auth.uid == uid;
      }
    }

    // Rooms root collection
    match /rooms/{roomId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.status == 'waiting'
        && request.resource.data.players.size() == 1
        && request.auth.uid in request.resource.data.players;

      allow update: if signedIn() && (
        hostStatusUpdateOnly(roomId)
        || playerJoinOrLeaveSelfOnly()
      );

      allow delete: if isRoomHost(roomId) && resource.data.status == 'ended';

      // players subcollection
      match /players/{uid} {
        allow read: if isRoomMember(roomId);

        allow create: if isRoomMember(roomId)
          && request.auth.uid == uid
          && request.resource.data.uid == uid;

        allow update: if isRoomMember(roomId)
          && (
            ownPlayerUpdateAllowed(uid)
            || freezeOpponentAllowed(roomId, uid)
          );

        allow delete: if isRoomMember(roomId)
          && (request.auth.uid == uid || isRoomHost(roomId));
      }
    }

    // Match history
    match /matches/{matchId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.keys().hasAll([
          'matchId', 'roomId', 'winnerUid', 'winnerName', 'winnerTime', 'createdAt'
        ]);
      allow update, delete: if false;
    }

    // Leaderboard
    match /leaderboard/{uid} {
      allow read: if true;

      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.wins is int
        && request.resource.data.totalMatches is int;

      allow update: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'wins', 'totalMatches', 'displayName'
        ])
        && request.resource.data.wins >= resource.data.wins
        && request.resource.data.totalMatches >= resource.data.totalMatches;

      allow delete: if false;
    }
  }
}
